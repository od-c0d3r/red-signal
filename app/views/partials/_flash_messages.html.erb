<div class="fixed bottom-6 right-6 z-50 space-y-3">
    <% if notice %>
    <div class="flex items-center rounded-xl bg-green-500 px-4 py-3 text-sm text-white shadow-lg
                animate-slide-in">
        <span class="font-medium"><%= notice %></span>
    </div>
    <% end %>

    <% if alert %>
    <div class="flex items-center rounded-xl bg-yellow-500 px-4 py-3 text-sm text-gray-900 shadow-lg
                animate-slide-in">
        <span class="font-medium"><%= alert %></span>
    </div>
    <% end %>
</div>
