<%= turbo_stream_from current_user if current_user %>

<header class="p-4 flex justify-between items-center text-white">
    <h1 class="text-3xl font-bold">RedSignal</h1>
    <% if current_user %>
        <% if current_user.user? %>
            <span id="user_now" class="text-xs"><%= "You Are, #{current_user.is_online ? "Online" : "Offline"}" if current_user.user? %></span>
        <% end %>
        <div class="flex flex-col items-end">
            <span class="font-bold"><%= "Hello, #{current_user.first_name}" %></span>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs" %>
        </div>
    <% end %>
</header>
