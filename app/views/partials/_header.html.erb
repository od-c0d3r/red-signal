<%= turbo_stream_from current_user if current_user %>

<header class="p-4 flex justify-between items-center text-white h-[100px]">
    <% if current_user %>
        <% if current_user.user? %>
            <%= link_to "RedSignal", user_path,class:"text-3xl font-bold"%>
            <span id="user_now" class="text-xs"><%= "You Are, #{current_user.is_online ? "Online" : "Offline"}" %></span>
        <% else %>
            <%= link_to "RedSignal", admin_path,class:"text-3xl font-bold"%>
        <% end %>
        <div class="flex flex-col items-end">
            <span class="font-bold"><%= "Hello, #{current_user.first_name}" %></span>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs" %>
        </div>
    <% end %>
</header>
